<script>
  let activeFormat = 'MP3';
  let downloadUrl = null;
  let downloadFileName = null;

  function selectTab(format) {
    activeFormat = format;
    document.getElementById('tabMP3').classList.toggle('active', format === 'MP3');
    document.getElementById('tabMP4').classList.toggle('active', format === 'MP4');
  }

 async function startConvert() {
  const url = document.getElementById('urlInput').value.trim();
  if (!url) {
    document.querySelector('.url-input-wrap').style.borderColor = '#ef4444';
    document.getElementById('urlInput').placeholder = 'Por favor, cole um link válido!';
    setTimeout(() => {
      document.querySelector('.url-input-wrap').style.borderColor = '';
      document.getElementById('urlInput').placeholder = 'Cole o link do YouTube aqui...';
    }, 2000);
    return;
  }

  // ✅ Verifica API antes de abrir o modal
  const isOnline = await checkApiStatus();
  if (!isOnline) {
    showServerOfflineModal();
    return;
  }

  openModal(url);
}

  async function openModal(videoUrl) {
    const overlay = document.getElementById('modalOverlay');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';

    // Reset state
    downloadUrl = null;
    downloadFileName = null;
    document.getElementById('modalStep1').style.display = 'flex';
    document.getElementById('modalStep2').style.display = 'none';
    document.getElementById('progressBar').style.width = '0%';
    document.getElementById('progressPct').textContent = '0%';
    document.getElementById('progressLabel').textContent = 'Iniciando conversão...';

    const format = activeFormat.toLowerCase(); // 'mp3' ou 'mp4'
    const endpoint = `http://209.50.228.75:3021/api/download/${format}`;
    const token = 'eyJhbGciOiJIUzI1';

    // Animate progress (fake) enquanto a API processa
    let pct = 0;
    let finished = false;
    const messages = [
      { at: 0,  text: 'Iniciando conversão...' },
      { at: 20, text: 'Analisando o vídeo...' },
      { at: 45, text: 'Extraindo o áudio...' },
      { at: 70, text: 'Otimizando o arquivo...' },
      { at: 90, text: 'Quase pronto...' },
    ];

    // Barra de progresso vai até 90% enquanto aguarda a API
    const interval = setInterval(() => {
      if (finished) return;
      if (pct < 90) {
        pct += 1;
        document.getElementById('progressBar').style.width = pct + '%';
        document.getElementById('progressPct').textContent = pct + '%';
        const msg = messages.filter(m => m.at <= pct).pop();
        if (msg) document.getElementById('progressLabel').textContent = msg.text;
      }
    }, 80);

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`,
        },
        body: JSON.stringify({ url: videoUrl }),
      });

      const data = await response.json();
      console.log(data);
      if (!response.ok) {
        throw new Error(data.error || 'Erro ao processar o vídeo.');
      }

      // Salva dados do download
      downloadUrl = `http://209.50.228.75:3021${data.url}`;
      downloadFileName = data.file;

      // Completa a barra para 100%
      finished = true;
      clearInterval(interval);
      pct = 100;
      document.getElementById('progressBar').style.width = '100%';
      document.getElementById('progressPct').textContent = '100%';
      document.getElementById('progressLabel').textContent = 'Concluído!';

      setTimeout(() => {
        document.getElementById('modalStep1').style.display = 'none';
        document.getElementById('modalStep2').style.display = 'flex';
      }, 400);

    } catch (error) {
      finished = true;
      clearInterval(interval);
      document.getElementById('progressLabel').textContent = '❌ ' + error.message;
      document.getElementById('progressBar').style.background = '#ef4444';
    }
  }

 async function downloadFile() {
  if (!downloadUrl) return;

  try {
    const token = 'eyJhbGciOiJIUzI1';

    const response = await fetch(downloadUrl, {
      headers: {
        'Authorization': `Bearer ${token}`,
      }
    });

    if (!response.ok) throw new Error('Falha ao baixar o arquivo.');

    const blob = await response.blob();
    const blobUrl = URL.createObjectURL(blob);

    const a = document.createElement('a');
    a.href = blobUrl;
    a.download = downloadFileName || 'download'; // força download pelo nome do arquivo
    a.style.display = 'none';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);

    setTimeout(() => URL.revokeObjectURL(blobUrl), 10000);

  } catch (error) {
    alert('Erro ao baixar o arquivo: ' + error.message);
  }
}

  function closeModal() {
    const overlay = document.getElementById('modalOverlay');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  function toggleFaq(btn) {
    btn.parentElement.classList.toggle('open');
  }

  async function checkApiStatus() {
  try {
    const response = await fetch('http://209.50.228.75:3021/api/download/status', {
      signal: AbortSignal.timeout(5000) // timeout de 5s
    });
    const data = await response.json();
    return data.status === 'ok';
  } catch {
    return false;
  }
}

function showServerOfflineModal() {
  // Cria o modal de erro se não existir
  if (!document.getElementById('offlineModal')) {
    const modal = document.createElement('div');
    modal.id = 'offlineModal';
    modal.innerHTML = `
      <div style="
        position: fixed; inset: 0; background: rgba(0,0,0,0.7);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999; backdrop-filter: blur(4px);
      ">
        <div style="
          background: #1a1a2e; border: 1px solid #ef4444;
          border-radius: 16px; padding: 40px; max-width: 420px;
          width: 90%; text-align: center; color: #fff;
          box-shadow: 0 0 40px rgba(239,68,68,0.3);
        ">
          <div style="font-size: 56px; margin-bottom: 16px;">🔴</div>
          <h2 style="color: #ef4444; margin: 0 0 12px; font-size: 22px;">Servidor Offline</h2>
          <p style="color: #aaa; margin: 0 0 8px; line-height: 1.6;">
            Não foi possível conectar ao servidor de conversão.
          </p>
          <p style="color: #666; font-size: 13px; margin: 0 0 28px;">
            O serviço pode estar em manutenção ou temporariamente indisponível. Tente novamente em alguns minutos.
          </p>
          <button onclick="document.getElementById('offlineModal').remove()" style="
            background: #ef4444; color: #fff; border: none;
            padding: 12px 32px; border-radius: 8px; font-size: 15px;
            cursor: pointer; font-weight: 600;
            transition: background 0.2s;
          " onmouseover="this.style.background='#dc2626'"
             onmouseout="this.style.background='#ef4444'">
            Fechar
          </button>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
  }
}

</script>
